{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Linux - Build Docker Image",
            "type": "shell",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "command": "./build.sh --skip-tests --skip-push-dockerhub",
            "options": {
                "cwd": "${workspaceFolder}"
            }
        },
        {
            "label": "Download git submodules",
            "type": "shell",
            "command": "git submodule foreach git pull origin main;",
            "problemMatcher": [],
            "promptOnClose": true
        },
        {
            "label": "Update git submodules",
            "type": "shell",
            "command": "git submodule update --init --recursive --remote;",
            "problemMatcher": [],
            "promptOnClose": true
        }
    ]
}
